# FastAPI
APP_NAME=MyAPI
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ComfyUI
COMFYUI_HOST=http://127.0.0.1:8188
